# Target modern browsers only, eliminates unnecessary legacy polyfills.
# Minimums are the first versions that natively support every Baseline feature
# our bundle uses (Array.prototype.at, Array.flat/flatMap, Object.fromEntries,
# Object.hasOwn, String.trimStart/End). Object.hasOwn is the binding constraint:
# it needs Chromium 93 (Chrome/Edge 93, Opera 79), Firefox 92, Safari 15.4.
[production]
chrome >= 93
firefox >= 92
safari >= 15.4
edge >= 93
opera >= 79
samsung >= 17

[development]
last 1 chrome version
last 1 firefox version
last 1 safari version
