{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup-ai-generations",
      "schedule": "0 4 * * *"
    }
  ]
}
